# Argus 0G Mainnet deployment
OG_RPC_URL=https://evmrpc.0g.ai
OG_CHAIN_ID=16661
OG_EXPLORER_BASE_URL=https://chainscan.0g.ai
DEPLOYMENT_MODE=0g
ARGUS_CHAIN_MODE=0g

# Never commit a real private key. Use a dedicated funded deployer wallet.
PRIVATE_KEY=0xREPLACE_WITH_DEPLOYER_PRIVATE_KEY_DO_NOT_COMMIT

# Storage defaults to honest local fallback.
ARGUS_STORAGE_MODE=local-fallback
OG_STORAGE_ENABLED=0
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=
OG_STORAGE_EXPLORER_BASE_URL=https://storagescan.0g.ai
OG_STORAGE_GATEWAY_URL=

# Optional deployment/demo controls.
ARGUS_MIN_DEPLOYER_BALANCE=1.5
ARGUS_DEMO_BOND=1.0
ARGUS_ALLOW_STORAGE_FALLBACK=0
OG_STORAGE_VERIFY_READBACK=0

# Galileo rehearsal examples only:
# OG_GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
# OG_GALILEO_CHAIN_ID=16602
# OG_GALILEO_EXPLORER_BASE_URL=https://chainscan-galileo.0g.ai
